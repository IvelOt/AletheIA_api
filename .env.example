# Aletheia Edge - Configuration (C++)

# HTTP API Configuration
PORT=8080
BIND_ADDR=0.0.0.0

# Biometric Thresholds
SIMILARITY_THRESHOLD=0.55
QUALITY_THRESHOLD=0.45

# Model Paths (Relative to the build directory)
CLASSIFIER_PATH=../../models/document_classifier.onnx
INSPIREFACE_MODEL_PATH=../../models/.inspireface/ms/tunmxy/InspireFace/Pikachu

# Database and Storage
DB_PATH=aletheia.db
STORAGE_DIR=storage/
